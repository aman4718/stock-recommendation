# ── Groq (free LLM — get key at console.groq.com) ───────────────
GROQ_API_KEY=your_groq_api_key_here

# ── ChromaDB Cloud (vector store — app.trychroma.com) ────────────
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=your_database_name_here

# ── App Settings ─────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── HuggingFace cache (redirect to /tmp to save disk quota) ──────
TRANSFORMERS_CACHE=/tmp/hf_cache
HF_HOME=/tmp/hf_home
